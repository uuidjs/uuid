{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "files": {
    "includes": ["**", "!**/dist"]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "rules": {
      "a11y": {
        "useHtmlLang": "off"
      },
      "complexity": {
        "useArrowFunction": "off"
      },
      "suspicious": {
        "noAssignInExpressions": "off"
      }
    }
  }
}
